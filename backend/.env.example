# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Port (local development)
PORT=5000

# MongoDB Connection String
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/?appName=YourApp

# JWT Secret Key for token signing (MUST be changed in production)
JWT_SECRET=your_jwt_secret_key_change_in_production

# JWT Token Expiry
JWT_EXPIRY=7d

# Node Environment
NODE_ENV=development

# Swagger API Documentation URL (optional - uses PORT as fallback)
# For local development, leave this empty or use: http://localhost:5000
# For production, set to your deployed backend URL: https://your-backend-url.com
SWAGGER_URL=
